# Backend Environment Variables

# Project
PROJECT_NAME=Neuralilux
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://neuralilux:neuralilux_password@postgres:5432/neuralilux

# Redis
REDIS_URL=redis://:redis_password@redis:6379/0

# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=change-me-in-production

# Qdrant Vector Database
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# JWT Authentication
SECRET_KEY=change-me-in-production-use-strong-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=info
