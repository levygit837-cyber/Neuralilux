# Backend Environment Variables

# Project
PROJECT_NAME=Neuralilux
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg://neuralilux:neuralilux_password@localhost:5434/neuralilux

# Redis
REDIS_URL=redis://:redis_password@localhost:6380/0

# Evolution API
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=change-me-in-production

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# RabbitMQ
RABBITMQ_URL=amqp://neuralilux:rabbitmq_password@localhost:5672/neuralilux

# JWT Authentication
SECRET_KEY=change-me-in-production-use-strong-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# LM Studio
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=qwen3.5-4b
LM_STUDIO_MAX_TOKENS=2048
LM_STUDIO_TEMPERATURE=0.7
LM_STUDIO_DISABLE_THINKING=false

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# Agent Configuration
AGENT_RESPONSE_MAX_TOKENS=250
AGENT_INFERENCE_PROVIDER=gemini

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=info

# Tool telemetry
TOOL_EVENT_PREVIEW_LIMIT=240
TOOL_EVENT_INCLUDE_RAW_PAYLOADS=false
